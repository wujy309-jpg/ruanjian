<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.mapper.GeneratedResourceMapper">

    <resultMap id="GeneratedResourceResultMap" type="com.exam.entity.GeneratedResource">
        <id property="id" column="id"/>
        <result property="pathNodeId" column="path_node_id"/>
        <result property="knowledgePointId" column="knowledge_point_id"/>
        <result property="resourceType" column="resource_type"/>
        <result property="title" column="title"/>
        <result property="contentJson" column="content_json" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="contentUrl" column="content_url"/>
        <result property="difficulty" column="difficulty"/>
        <result property="generatedBySessionId" column="generated_by_session_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectByPathNodeId" resultMap="GeneratedResourceResultMap">
        SELECT * FROM generated_resource WHERE path_node_id = #{pathNodeId}
    </select>

    <select id="selectByKnowledgePointId" resultMap="GeneratedResourceResultMap">
        SELECT * FROM generated_resource WHERE knowledge_point_id = #{kpId}
    </select>

    <select id="selectByPathNodeIds" resultMap="GeneratedResourceResultMap">
        SELECT * FROM generated_resource
        WHERE path_node_id IN
        <foreach collection="pathNodeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
